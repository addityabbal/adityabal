<script>
function openLightbox(previewEl) {
  const img = previewEl.querySelector('img');
  document.getElementById('certLightboxImg').src = img.src;
  document.getElementById('certLightboxImg').alt = img.alt;
  document.getElementById('certLightbox').classList.add('active');
  document.body.style.overflow = 'hidden';
}
function closeLightbox() {
  document.getElementById('certLightbox').classList.remove('active');
  document.body.style.overflow = '';
}
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') closeLightbox();
});
</script>

<script>
  // Theme toggle
  (function() {
    const root    = document.documentElement;
    const btn     = document.getElementById('themeToggle');
    const STORAGE = 'ab-theme';
    const saved   = localStorage.getItem(STORAGE);
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const initial = saved || 'dark';
    root.setAttribute('data-theme', initial);
    btn.addEventListener('click', function() {
      const current = root.getAttribute('data-theme');
      const next    = current === 'dark' ? 'light' : 'dark';
      root.setAttribute('data-theme', next);
      localStorage.setItem(STORAGE, next);
    });
  })();
</script>

<!-- COUNTER ANIMATION -->
<script>
(function() {
  // Parse the target value and suffix from text like "10M+", "3.8M", "+15%", "11+"
  function parseMetric(text) {
    text = text.trim();
    var prefix = '';
    var suffix = '';
    var numStr = text;

    // Handle leading +
    if (numStr.startsWith('+')) {
      prefix = '+';
      numStr = numStr.slice(1);
    }

    // Extract trailing non-numeric suffix (M, %, +)
    var match = numStr.match(/^([\d.]+)(.*)$/);
    if (!match) return null;

    var num = parseFloat(match[1]);
    suffix = match[2] || '';

    return { num: num, prefix: prefix, suffix: suffix, isFloat: numStr.indexOf('.') !== -1 };
  }

  function formatNum(val, isFloat) {
    if (isFloat) return val.toFixed(1);
    return Math.floor(val).toString();
  }

  function animateCounter(el, parsed, duration) {
    var start = null;
    var startVal = 0;
    var endVal = parsed.num;

    el.classList.add('counting');

    function step(timestamp) {
      if (!start) start = timestamp;
      var progress = Math.min((timestamp - start) / duration, 1);
      // Ease out cubic
      var eased = 1 - Math.pow(1 - progress, 3);
      var current = startVal + (endVal - startVal) * eased;

      el.textContent = parsed.prefix + formatNum(current, parsed.isFloat) + parsed.suffix;

      if (progress < 1) {
        requestAnimationFrame(step);
      } else {
        el.textContent = parsed.prefix + formatNum(endVal, parsed.isFloat) + parsed.suffix;
        el.classList.remove('counting');
      }
    }

    requestAnimationFrame(step);
  }

  function initCounters() {
    var metricNums = document.querySelectorAll('.metric-num');
    if (!metricNums.length) return;

    var observed = false;

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting && !observed) {
          observed = true;
          observer.disconnect();

          metricNums.forEach(function(el, i) {
            var parsed = parseMetric(el.textContent);
            if (!parsed) return;
            // Stagger each counter by 150ms
            setTimeout(function() {
              animateCounter(el, parsed, 1400);
            }, i * 150);
          });
        }
      });
    }, { threshold: 0.3 });

    // Observe the metrics bar container
    var metricsBar = document.querySelector('.metrics-bar');
    if (metricsBar) observer.observe(metricsBar);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCounters);
  } else {
    initCounters();
  }
})();
</script>

</body>
</html>