---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Portfolio Deploy — Aditya Bal</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #0a0a0a; color: #f0ece4; font-family: 'Segoe UI', sans-serif; padding: 1.5rem 1.2rem; min-height: 100vh; }
  .wrap { max-width: 780px; margin: 0 auto; }
  h1 { font-family: Georgia, serif; font-size: 1.6rem; font-weight: 900; color: #e8c97a; }
  .sub { color: #555; font-size: 0.75rem; margin: 0.2rem 0 0; }
  .header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1.3rem; flex-wrap: wrap; gap: 0.8rem; }
  .stat { background: #141414; border: 1px solid #222; border-radius: 6px; padding: 0.5rem 1rem; text-align: center; min-width: 80px; }
  .stat-num { font-size: 1.3rem; font-weight: 800; color: #e8c97a; }
  .stat-label { font-size: 0.58rem; color: #444; text-transform: uppercase; letter-spacing: 0.1em; }
  .live-bar { background: #0d1a0d; border: 1px solid #1c3a1c; border-radius: 6px; padding: 0.6rem 1rem; display: flex; align-items: center; gap: 0.6rem; margin-bottom: 1rem; }
  .dot { width: 7px; height: 7px; border-radius: 50%; background: #4caf50; box-shadow: 0 0 5px #4caf50; flex-shrink: 0; animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.5} }
  .live-url { color: #e8c97a; font-weight: 600; font-size: 0.85rem; text-decoration: none; }
  .live-tag { margin-left: auto; font-size: 0.62rem; color: #4caf50; font-weight: 700; letter-spacing: 0.1em; }
  .card { background: #141414; border: 1px solid #1e1e1e; border-radius: 8px; padding: 1.2rem; margin-bottom: 0.9rem; }
  .card-label { font-size: 0.62rem; letter-spacing: 0.13em; text-transform: uppercase; color: #e8c97a; font-family: monospace; display: block; margin-bottom: 0.7rem; }
  .badge { background: #0d1a0d; color: #4caf50; padding: 0.1rem 0.45rem; border-radius: 3px; font-size: 0.62rem; margin-left: 0.5rem; }
  .row { display: flex; gap: 0.5rem; }
  input[type=password], input[type=text], input[type=email] {
    flex: 1; background: #0a0a0a; border: 1px solid #2a2a2a; border-radius: 5px;
    padding: 0.6rem 0.85rem; color: #f0ece4; font-size: 0.78rem; font-family: monospace; outline: none; width: 100%;
  }
  input:focus { border-color: #e8c97a44; }
  .btn { border: none; border-radius: 5px; padding: 0.6rem 1rem; cursor: pointer; font-size: 0.78rem; font-weight: 600; transition: all 0.2s; }
  .btn-gold { background: #e8c97a; color: #0a0a0a; }
  .btn-gold:hover { background: #c9a84c; }
  .btn-ghost { background: transparent; border: 1px solid #2a2a2a; color: #666; }
  .btn-ghost:hover { border-color: #555; color: #aaa; }
  .hint { font-size: 0.67rem; color: #3a3a3a; margin: 0.5rem 0 0; line-height: 1.5; }
  .hint strong { color: #555; }
  textarea { width: 100%; background: #0a0a0a; border: 1px solid #2a2a2a; border-radius: 5px; padding: 0.7rem; color: #f0ece4; font-size: 0.75rem; font-family: monospace; outline: none; resize: vertical; line-height: 1.5; }
  textarea:focus { border-color: #e8c97a44; }
  .size-tag { font-size: 0.67rem; font-family: monospace; }
  .size-ok { color: #4caf50; }
  .size-empty { color: #444; }
  .quick-btns { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-bottom: 0.6rem; }
  .quick-btn { background: #1a1a1a; border: 1px solid #252525; border-radius: 4px; padding: 0.25rem 0.65rem; color: #777; cursor: pointer; font-size: 0.7rem; }
  .quick-btn:hover { background: #222; color: #aaa; }
  .deploy-btn { width: 100%; padding: 0.9rem; border-radius: 7px; border: none; font-weight: 800; font-size: 0.95rem; letter-spacing: 0.03em; margin-bottom: 0.9rem; cursor: pointer; transition: all 0.2s; }
  .deploy-idle { background: #e8c97a; color: #0a0a0a; }
  .deploy-idle:hover { background: #c9a84c; transform: translateY(-1px); }
  .deploy-loading { background: #6a5a28; color: #0a0a0a; cursor: not-allowed; }
  .deploy-success { background: #1a3a1a; color: #f0ece4; }
  .deploy-error { background: #3a1010; color: #f0ece4; }
  .log-wrap { background: #060606; border: 1px solid #181818; border-radius: 8px; padding: 1rem; font-family: monospace; font-size: 0.72rem; margin-bottom: 0.9rem; }
  .log-title { font-size: 0.58rem; letter-spacing: 0.12em; text-transform: uppercase; color: #2e2e2e; margin-bottom: 0.6rem; }
  .log-line { display: flex; gap: 1rem; margin-bottom: 0.2rem; }
  .log-time { color: #2e2e2e; flex-shrink: 0; }
  .log-info { color: #888; }
  .log-success { color: #e8c97a; }
  .log-error { color: #ff6b6b; }
  .success-box { margin-top: 0.75rem; padding: 0.7rem; background: #0d1a0d; border-radius: 5px; border: 1px solid #1c3a1c; }
  .success-title { color: #4caf50; font-weight: 700; margin-bottom: 0.3rem; }
  .success-sub { color: #555; font-size: 0.68rem; }
  .how-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 0.7rem; text-align: center; }
  .how-icon { font-size: 1.2rem; margin-bottom: 0.2rem; }
  .how-title { font-size: 0.72rem; font-weight: 700; color: #e8c97a; margin-bottom: 0.15rem; }
  .how-desc { font-size: 0.65rem; color: #444; line-height: 1.4; }
  .footer-label { font-size: 0.58rem; letter-spacing: 0.13em; text-transform: uppercase; color: #333; margin-bottom: 0.8rem; }
  @media(max-width:600px){ .how-grid{grid-template-columns:repeat(2,1fr);} .header{flex-direction:column;} }
</style>
</head>
<body>
<div class="wrap">

  <!-- Header -->
  <div class="header">
    <div>
      <h1>🚀 Portfolio Deploy</h1>
      <p class="sub">addityabbal/adityabal → adityabal.com</p>
    </div>
    <div style="display:flex;gap:0.6rem;">
      <div class="stat">
        <div class="stat-num" id="deployCount">0</div>
        <div class="stat-label">Deploys</div>
      </div>
      <div class="stat" style="min-width:120px;">
        <div class="stat-num" id="lastDeploy" style="font-size:0.72rem;color:#333;">—</div>
        <div class="stat-label">Last Deploy</div>
      </div>
    </div>
  </div>

  <!-- Live bar -->
  <div class="live-bar">
    <span class="dot"></span>
    <span style="font-size:0.75rem;color:#555;">Live at:</span>
    <a href="https://adityabal.com" target="_blank" class="live-url">adityabal.com</a>
    <span class="live-tag">● LIVE</span>
  </div>

  <!-- Token -->
  <div class="card">
    <span class="card-label">🔑 GitHub Token <span id="tokenBadge" style="display:none;" class="badge">✓ Saved</span></span>
    <div class="row">
      <input type="password" id="tokenInput" placeholder="ghp_xxxxxxxxxxxxxxxxxxxx" />
      <button class="btn btn-ghost" onclick="toggleToken()">Show</button>
      <button class="btn btn-gold" onclick="saveToken()">Save</button>
      <button class="btn btn-ghost" id="clearBtn" style="display:none;" onclick="clearToken()">Clear</button>
    </div>
    <p class="hint">github.com → Settings → Developer settings → Personal access tokens → Tokens (classic) → Generate new → tick <strong>repo</strong></p>
  </div>

  <!-- HTML -->
  <div class="card">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.7rem;">
      <span class="card-label" style="margin:0;">📄 Portfolio HTML</span>
      <span class="size-tag size-empty" id="sizeTag">empty — paste HTML below</span>
    </div>
    <textarea id="htmlInput" rows="7" placeholder="1. Download aditya-bal-portfolio.html from Claude&#10;2. Open in Notepad → Ctrl+A → Ctrl+C&#10;3. Click here → Ctrl+V to paste" oninput="updateSize()"></textarea>
    <button class="btn btn-ghost" style="margin-top:0.5rem;" onclick="document.getElementById('htmlInput').value='';updateSize()">Clear</button>
  </div>

  <!-- Commit -->
  <div class="card">
    <span class="card-label">💬 What changed?</span>
    <div class="quick-btns">
      <button class="quick-btn" onclick="setMsg('Add section')">Add section</button>
      <button class="quick-btn" onclick="setMsg('Update content')">Update content</button>
      <button class="quick-btn" onclick="setMsg('Fix typo')">Fix typo</button>
      <button class="quick-btn" onclick="setMsg('Add certification')">Add certification</button>
      <button class="quick-btn" onclick="setMsg('Update skills')">Update skills</button>
      <button class="quick-btn" onclick="setMsg('Add project')">Add project</button>
    </div>
    <input type="text" id="commitMsg" placeholder="e.g. Add JioPC case study, Update certifications..." onkeydown="if(event.key==='Enter')deploy()" style="width:100%;" />
    <p class="hint">Tip: Press Enter to deploy quickly</p>
  </div>

  <!-- Deploy Button -->
  <button class="deploy-btn deploy-idle" id="deployBtn" onclick="deploy()">🚀  Deploy to adityabal.com</button>

  <!-- Log -->
  <div class="log-wrap" id="logWrap" style="display:none;">
    <div class="log-title">Deploy Log</div>
    <div id="logLines"></div>
    <div id="successBox" style="display:none;" class="success-box">
      <div class="success-title">🎉 Cloudflare is building now!</div>
      <div class="success-sub">Live at <a href="https://adityabal.com" target="_blank" style="color:#e8c97a;">adityabal.com</a> in ~60 seconds</div>
    </div>
  </div>

  <!-- How it works -->
  <div class="card">
    <div class="footer-label">How to use this dashboard</div>
    <div class="how-grid">
      <div><div class="how-icon">1️⃣</div><div class="how-title">Ask Claude</div><div class="how-desc">Request changes in chat</div></div>
      <div><div class="how-icon">2️⃣</div><div class="how-title">Download HTML</div><div class="how-desc">Get updated file from Claude</div></div>
      <div><div class="how-icon">3️⃣</div><div class="how-title">Paste & Label</div><div class="how-desc">Drop HTML above + describe it</div></div>
      <div><div class="how-icon">4️⃣</div><div class="how-title">One Click</div><div class="how-desc">Pushes to GitHub → live in 60s</div></div>
    </div>
  </div>

</div>

<script>
const REPO_OWNER = 'addityabbal';
const REPO_NAME  = 'adityabal';
const FILE_PATH  = 'src/pages/index.astro';
const BRANCH     = 'main';

let deployCount = parseInt(localStorage.getItem('deploy_count') || '0');
let showingToken = false;

// Init
document.getElementById('deployCount').textContent = deployCount;
const saved = localStorage.getItem('gh_token');
if (saved) {
  document.getElementById('tokenInput').value = saved;
  document.getElementById('tokenBadge').style.display = 'inline';
  document.getElementById('clearBtn').style.display = 'inline-block';
}
const lastD = localStorage.getItem('last_deploy');
if (lastD) {
  document.getElementById('lastDeploy').textContent = lastD;
  document.getElementById('lastDeploy').style.color = '#e8c97a';
}

function toggleToken() {
  const inp = document.getElementById('tokenInput');
  const btn = inp.nextElementSibling;
  showingToken = !showingToken;
  inp.type = showingToken ? 'text' : 'password';
  btn.textContent = showingToken ? 'Hide' : 'Show';
}

function saveToken() {
  const t = document.getElementById('tokenInput').value.trim();
  if (!t) return;
  localStorage.setItem('gh_token', t);
  document.getElementById('tokenBadge').style.display = 'inline';
  document.getElementById('clearBtn').style.display = 'inline-block';
  addLog('✅ Token saved', 'success');
}

function clearToken() {
  localStorage.removeItem('gh_token');
  document.getElementById('tokenInput').value = '';
  document.getElementById('tokenBadge').style.display = 'none';
  document.getElementById('clearBtn').style.display = 'none';
  addLog('🗑️ Token cleared', 'info');
}

function updateSize() {
  const val = document.getElementById('htmlInput').value;
  const tag = document.getElementById('sizeTag');
  if (val.length > 100) {
    tag.textContent = `✅ ${(val.length/1024).toFixed(1)} KB ready`;
    tag.className = 'size-tag size-ok';
  } else {
    tag.textContent = 'empty — paste HTML below';
    tag.className = 'size-tag size-empty';
  }
}

function setMsg(m) { document.getElementById('commitMsg').value = m; }

function addLog(msg, type) {
  const wrap = document.getElementById('logWrap');
  const lines = document.getElementById('logLines');
  wrap.style.display = 'block';
  const time = new Date().toLocaleTimeString();
  const div = document.createElement('div');
  div.className = 'log-line';
  div.innerHTML = `<span class="log-time">${time}</span><span class="log-${type}">${msg}</span>`;
  lines.appendChild(div);
  wrap.scrollTop = wrap.scrollHeight;
}

function setBtn(state) {
  const btn = document.getElementById('deployBtn');
  btn.className = `deploy-btn deploy-${state}`;
  btn.disabled = state === 'loading';
  if (state === 'loading') btn.textContent = '⏳  Pushing to GitHub → Cloudflare building...';
  else if (state === 'success') btn.textContent = '✅  Deployed! Click to deploy again';
  else if (state === 'error') btn.textContent = '❌  Failed — check log above & retry';
  else btn.textContent = '🚀  Deploy to adityabal.com';
}

async function deploy() {
  const token = document.getElementById('tokenInput').value.trim();
  const html  = document.getElementById('htmlInput').value;
  const msg   = document.getElementById('commitMsg').value.trim();

  if (!token) { addLog('❌ Enter your GitHub token first', 'error'); return; }
  if (!html)  { addLog('❌ Paste your HTML content first', 'error'); return; }
  if (!msg)   { addLog('❌ Enter a commit message', 'error'); return; }

  setBtn('loading');
  document.getElementById('logLines').innerHTML = '';
  document.getElementById('successBox').style.display = 'none';
  document.getElementById('logWrap').style.display = 'block';

  try {
    addLog('🔍 Fetching current file from GitHub...', 'info');
    const getRes = await fetch(
      `https://api.github.com/repos/${REPO_OWNER}/${REPO_NAME}/contents/${FILE_PATH}?ref=${BRANCH}`,
      { headers: { Authorization: `token ${token}`, Accept: 'application/vnd.github.v3+json' } }
    );
    if (!getRes.ok) { const e = await getRes.json(); throw new Error(e.message || `GitHub ${getRes.status}`); }
    const fileData = await getRes.json();
    addLog(`✅ Got SHA: ${fileData.sha.slice(0,8)}...`, 'success');

    const astroContent = html.trimStart().startsWith('---') ? html : `---\n---\n${html}`;
    const encoded = btoa(unescape(encodeURIComponent(astroContent)));

    addLog('📤 Pushing to GitHub...', 'info');
    const putRes = await fetch(
      `https://api.github.com/repos/${REPO_OWNER}/${REPO_NAME}/contents/${FILE_PATH}`,
      {
        method: 'PUT',
        headers: { Authorization: `token ${token}`, Accept: 'application/vnd.github.v3+json', 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: msg, content: encoded, sha: fileData.sha, branch: BRANCH })
      }
    );
    if (!putRes.ok) { const e = await putRes.json(); throw new Error(e.message || `Push failed ${putRes.status}`); }
    const result = await putRes.json();

    addLog(`✅ Commit: ${result.commit.sha.slice(0,8)} pushed!`, 'success');
    addLog('⚡ Cloudflare building... live in ~60s at adityabal.com 🌐', 'success');

    deployCount++;
    const now = new Date().toLocaleTimeString();
    localStorage.setItem('deploy_count', deployCount);
    localStorage.setItem('last_deploy', now);
    document.getElementById('deployCount').textContent = deployCount;
    document.getElementById('lastDeploy').textContent = now;
    document.getElementById('lastDeploy').style.color = '#e8c97a';
    document.getElementById('successBox').style.display = 'block';
    document.getElementById('commitMsg').value = '';
    document.getElementById('htmlInput').value = '';
    updateSize();
    setBtn('success');

  } catch(err) {
    addLog(`❌ ${err.message}`, 'error');
    setBtn('error');
  }
}
</script>
</body>
</html>
