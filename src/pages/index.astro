<style>

  /* ── THEME TOGGLE ── */
  :root {
    --bg: #0a0a0a;
    --bg2: #111111;
    --bg3: #181818;
    --border: rgba(255,255,255,0.07);
    --accent: #e8c97a;
    --accent2: #c9a84c;
    --text: #f0ece4;
    --muted: #888880;
    --card: #141414;
    --shadow: rgba(0,0,0,0.4);
  }

  [data-theme="light"] {
    --bg: #f5f2ee;
    --bg2: #ede9e3;
    --bg3: #e4dfd8;
    --border: rgba(0,0,0,0.09);
    --accent: #b8860b;
    --accent2: #9a6f0a;
    --text: #1a1714;
    --muted: #6b6560;
    --card: #faf7f4;
    --shadow: rgba(0,0,0,0.12);
  }

  /* Toggle button */
  .theme-toggle {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 50px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0;
    padding: 3px;
    width: 64px;
    height: 32px;
    position: relative;
    transition: background 0.3s, border-color 0.3s;
    flex-shrink: 0;
  }
  .theme-toggle:hover { border-color: var(--accent); }

  .theme-toggle-track {
    position: absolute; inset: 3px;
    border-radius: 50px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 5px;
    pointer-events: none;
  }
  .theme-toggle-icon {
    font-size: 0.75rem;
    line-height: 1;
    transition: opacity 0.2s;
  }
  .icon-moon { opacity: 1; }
  .icon-sun  { opacity: 0.4; }
  [data-theme="light"] .icon-moon { opacity: 0.4; }
  [data-theme="light"] .icon-sun  { opacity: 1; }

  .theme-toggle-thumb {
    width: 24px; height: 24px;
    border-radius: 50%;
    background: var(--accent);
    position: absolute;
    top: 4px; left: 4px;
    transition: transform 0.28s cubic-bezier(.34,1.56,.64,1), background 0.3s;
    box-shadow: 0 1px 4px rgba(0,0,0,0.25);
    display: flex; align-items: center; justify-content: center;
    font-size: 0.65rem;
  }
  [data-theme="light"] .theme-toggle-thumb {
    transform: translateX(32px);
  }

  /* Light mode overrides for elements using hardcoded dark colors */
  [data-theme="light"] nav {
    background: rgba(245,242,238,0.92);
  }
  [data-theme="light"] .hero::before {
    background: radial-gradient(circle, rgba(184,134,11,0.07) 0%, transparent 65%);
  }
  [data-theme="light"] .contact-inner::before {
    background: radial-gradient(circle, rgba(184,134,11,0.06) 0%, transparent 65%);
  }
  [data-theme="light"] .hero-avatar {
    border-color: rgba(184,134,11,0.35);
    box-shadow: 0 0 40px rgba(184,134,11,0.10), 0 20px 60px rgba(0,0,0,0.12);
  }
  [data-theme="light"] .timeline::before { background: var(--border); }
  [data-theme="light"] .timeline-item::before {
    background: var(--accent);
    border-color: var(--bg);
  }
  [data-theme="light"] .product-card::before,
  [data-theme="light"] .talk-card::before { background: var(--accent); }
  [data-theme="light"] .cert-view-btn { color: #1a1714; }
  [data-theme="light"] .cert-lightbox { background: rgba(0,0,0,0.85); }
  [data-theme="light"] .divider { background: var(--accent); }
  [data-theme="light"] .btn-primary { color: #1a1714; }
  [data-theme="light"] .metric-num { color: var(--accent); }
  [data-theme="light"] .section-label { color: var(--accent); }
  [data-theme="light"] .hero-tag {
    background: rgba(184,134,11,0.08);
    border-color: rgba(184,134,11,0.25);
  }
  [data-theme="light"] .tag,
  [data-theme="light"] .cert-skill-tag {
    background: rgba(184,134,11,0.06);
    border-color: rgba(184,134,11,0.18);
  }
  [data-theme="light"] .skill-pill {
    background: rgba(0,0,0,0.04);
    border-color: rgba(0,0,0,0.09);
    color: var(--text);
  }
  [data-theme="light"] .cert-id { color: #999; }
  [data-theme="light"] footer small a { color: #999 !important; }
  [data-theme="light"] .cert-preview { background: #f8f8f8; }
  [data-theme="light"] .talk-thumb-overlay {
    background: linear-gradient(to bottom, transparent 40%, rgba(245,242,238,0.85) 100%);
  }
  [data-theme="light"] .metrics-bar {
    background: var(--bg2);
    border-color: var(--border);
  }
  [data-theme="light"] .award-card:hover,
  [data-theme="light"] .product-card:hover,
  [data-theme="light"] .cert-card-full:hover,
  [data-theme="light"] .talk-card:hover {
    border-color: rgba(184,134,11,0.3);
  }
  [data-theme="light"] .contact-link:hover { border-color: var(--accent); color: var(--accent); }
  [data-theme="light"] .nav-links a:hover { color: var(--accent); }
  [data-theme="light"] .btn-ghost:hover { border-color: var(--accent); color: var(--accent); }
  [data-theme="light"] .talk-org {
    background: rgba(0,0,0,0.04);
    border-color: var(--border);
  }
  [data-theme="light"] #certLightbox { background: rgba(0,0,0,0.88); }



  /* SKIP LINK (Accessibility + SEO) */
  .skip-link {
    position: absolute; top: -100px; left: 1rem;
    background: var(--accent); color: #0a0a0a;
    padding: 0.5rem 1rem; border-radius: 3px;
    font-weight: 600; font-size: 0.85rem;
    text-decoration: none; z-index: 9999;
    transition: top 0.2s;
  }
  .skip-link:focus { top: 1rem; }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 16px;
    line-height: 1.6;
    overflow-x: hidden;
  }

  /* NAV */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; justify-content: space-between; align-items: center;
    padding: 1.2rem 4rem;
    background: rgba(10,10,10,0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .nav-logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--accent);
    text-decoration: none;
    letter-spacing: 0.02em;
  }
  .nav-links { display: flex; gap: 2rem; list-style: none; }
  .nav-links a {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--muted);
    text-decoration: none;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--accent); }

  /* HERO */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 8rem 4rem 4rem;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute; top: -200px; right: -200px;
    width: 700px; height: 700px;
    background: radial-gradient(circle, rgba(232,201,122,0.08) 0%, transparent 65%);
    pointer-events: none;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 4rem;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }
  .hero-tag {
    display: inline-block;
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    background: rgba(232,201,122,0.08);
    border: 1px solid rgba(232,201,122,0.2);
    padding: 0.35rem 0.9rem;
    border-radius: 2px;
    margin-bottom: 1.8rem;
  }
  .hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(3rem, 6vw, 5.5rem);
    font-weight: 900;
    line-height: 1.05;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }
  .hero h1 span { color: var(--accent); }
  .hero-sub {
    font-size: 1.05rem;
    color: var(--muted);
    max-width: 540px;
    margin-bottom: 2.5rem;
    line-height: 1.7;
  }
  .hero-ctas { display: flex; gap: 1rem; flex-wrap: wrap; }
  .btn-primary {
    padding: 0.85rem 2rem;
    background: var(--accent);
    color: #0a0a0a;
    font-weight: 600;
    font-size: 0.88rem;
    letter-spacing: 0.04em;
    border: none;
    border-radius: 3px;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
    display: inline-block;
  }
  .btn-primary:hover { background: var(--accent2); transform: translateY(-1px); }
  .btn-ghost {
    padding: 0.85rem 2rem;
    background: transparent;
    color: var(--text);
    font-weight: 500;
    font-size: 0.88rem;
    letter-spacing: 0.04em;
    border: 1px solid var(--border);
    border-radius: 3px;
    cursor: pointer;
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
    display: inline-block;
  }
  .btn-ghost:hover { border-color: var(--accent); color: var(--accent); }

  .hero-avatar {
    width: 260px; height: 260px;
    border-radius: 50%;
    border: 3px solid rgba(232,201,122,0.35);
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
    box-shadow: 0 0 40px rgba(232,201,122,0.10), 0 20px 60px rgba(0,0,0,0.5);
  }
  .hero-avatar::after {
    content: '';
    position: absolute; inset: -12px;
    border-radius: 50%;
    border: 1px solid rgba(232,201,122,0.12);
  }
  .hero-avatar img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    filter: contrast(1.05) brightness(1.02);
  }

  /* METRICS BAR */
  .metrics-bar {
    background: var(--bg2);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 2.5rem 4rem;
  }
  .metrics-inner {
    max-width: 1200px; margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    text-align: center;
  }
  .metric-item {}
  .metric-num {
    font-family: 'Playfair Display', serif;
    font-size: 2.8rem;
    font-weight: 900;
    color: var(--accent);
    line-height: 1;
    margin-bottom: 0.4rem;
    transition: opacity 0.3s;
  }
  .metric-num.counting {
    opacity: 0.85;
  }
  .metric-label {
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .metric-divider {
    width: 1px;
    background: var(--border);
    align-self: stretch;
  }

  /* SECTIONS */
  section {
    padding: 6rem 4rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  .section-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.8rem;
  }
  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 3.5vw, 2.8rem);
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 3rem;
  }
  .divider {
    width: 48px; height: 2px;
    background: var(--accent);
    margin-bottom: 1.5rem;
  }

  /* ABOUT */
  .about-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 5rem;
    align-items: start;
  }
  .about-text p { color: var(--muted); line-height: 1.85; margin-bottom: 1.2rem; font-size: 1.02rem; }
  .about-text p strong { color: var(--text); font-weight: 600; }
  .about-sidebar {}
  .sidebar-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1.6rem;
    margin-bottom: 1.2rem;
  }
  .sidebar-card h4 {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
    font-family: 'DM Mono', monospace;
  }
  .sidebar-card p, .sidebar-card li {
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.6;
  }
  .sidebar-card ul { list-style: none; }
  .sidebar-card ul li::before { content: '→ '; color: var(--accent); font-size: 0.75rem; }

  /* PRODUCTS */
  .products-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  .product-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 2rem;
    transition: border-color 0.25s, transform 0.2s;
    position: relative;
    overflow: hidden;
  }
  .product-card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s;
  }
  .product-card:hover::before { transform: scaleX(1); }
  .product-card:hover {
    border-color: rgba(232,201,122,0.2);
    transform: translateY(-3px);
  }
  .product-icon {
    font-size: 2rem;
    margin-bottom: 1rem;
    min-height: 2.5rem;
    display: flex;
    align-items: center;
  }
  .product-icon img {
    height: 2.5rem;
    width: auto;
    max-width: 9rem;
    object-fit: contain;
  }
  .product-card h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.35rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }
  .product-card .product-sub {
    font-size: 0.8rem;
    color: var(--accent);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-family: 'DM Mono', monospace;
    margin-bottom: 0.9rem;
  }
  .product-card p { color: var(--muted); font-size: 0.93rem; line-height: 1.65; margin-bottom: 1.2rem; }
  .product-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }

  /* Article thumbnail on product cards */
  .product-article-link {
    display: block;
    margin-top: 1.2rem;
    text-decoration: none;
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid var(--border);
    transition: border-color 0.25s, transform 0.2s;
    position: relative;
  }
  .product-article-link:hover {
    border-color: rgba(232,201,122,0.4);
    transform: translateY(-2px);
  }
  .product-article-thumb {
    width: 100%;
    height: 120px;
    object-fit: cover;
    display: block;
    background: var(--bg2);
  }
  .product-article-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.7rem;
    background: var(--card);
    font-size: 0.72rem;
    color: var(--accent);
    font-family: 'DM Mono', monospace;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-top: 1px solid var(--border);
  }
  .product-article-label svg {
    flex-shrink: 0;
    opacity: 0.7;
  }
  .product-article-label span {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--muted);
    font-size: 0.68rem;
  }
  .tag {
    font-size: 0.72rem;
    padding: 0.25rem 0.7rem;
    background: rgba(232,201,122,0.07);
    border: 1px solid rgba(232,201,122,0.15);
    border-radius: 2px;
    color: var(--muted);
    letter-spacing: 0.05em;
  }

  /* EXPERIENCE */
  .timeline { position: relative; padding-left: 2rem; }
  .timeline::before {
    content: '';
    position: absolute; left: 0; top: 8px; bottom: 0;
    width: 1px;
    background: var(--border);
  }
  .timeline-item {
    position: relative;
    padding-bottom: 3.5rem;
  }
  .timeline-item::before {
    content: '';
    position: absolute; left: -2.4rem; top: 8px;
    width: 10px; height: 10px;
    border-radius: 50%;
    background: var(--accent);
    border: 2px solid var(--bg);
  }
  .timeline-meta {
    font-family: 'DM Mono', monospace;
    font-size: 0.73rem;
    color: var(--accent);
    letter-spacing: 0.08em;
    margin-bottom: 0.5rem;
  }
  .timeline-role {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
  }
  .timeline-company {
    font-size: 0.9rem;
    color: var(--muted);
    margin-bottom: 1.2rem;
  }
  .timeline-bullets { list-style: none; }
  .timeline-bullets li {
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.7;
    padding: 0.3rem 0;
    padding-left: 1.2rem;
    position: relative;
  }
  .timeline-bullets li::before {
    content: '▸';
    color: var(--accent);
    position: absolute; left: 0;
    font-size: 0.7rem;
    top: 0.45rem;
  }
  .timeline-bullets li strong { color: var(--text); }

  /* AWARDS */
  .awards-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.2rem;
  }
  .award-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1.6rem;
    display: flex;
    gap: 1.2rem;
    align-items: flex-start;
    transition: border-color 0.2s;
  }
  .award-card:hover { border-color: rgba(232,201,122,0.2); }
  .award-icon {
    font-size: 1.6rem;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .award-card h4 {
    font-family: 'Playfair Display', serif;
    font-size: 1.02rem;
    font-weight: 700;
    margin-bottom: 0.3rem;
  }
  .award-card p { font-size: 0.84rem; color: var(--muted); line-height: 1.55; }
  .award-year {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    color: var(--accent);
    letter-spacing: 0.1em;
    margin-bottom: 0.4rem;
  }

  /* SKILLS */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .skill-group {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1.8rem;
  }
  .skill-group h4 {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.2rem;
  }
  .skill-pills { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .skill-pill {
    font-size: 0.78rem;
    padding: 0.3rem 0.75rem;
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border);
    border-radius: 2px;
    color: var(--text);
  }

  /* CERTS */
  .certs-list { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; }
  .cert-item {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1.2rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .cert-icon { font-size: 1.4rem; flex-shrink: 0; }
  .cert-item p { font-size: 0.88rem; color: var(--text); line-height: 1.4; }
  .cert-item span { font-size: 0.75rem; color: var(--muted); }

  /* CONTACT */
  .contact-inner {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 4rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .contact-inner::before {
    content: '';
    position: absolute; bottom: -100px; right: -100px;
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(232,201,122,0.05) 0%, transparent 65%);
    pointer-events: none;
  }
  .contact-inner h2 {
    font-family: 'Playfair Display', serif;
    font-size: 2.4rem;
    margin-bottom: 1rem;
  }
  .contact-inner p { color: var(--muted); margin-bottom: 2rem; font-size: 1rem; }
  .contact-links { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  .contact-link {
    display: flex; align-items: center; gap: 0.6rem;
    padding: 0.8rem 1.6rem;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--text);
    text-decoration: none;
    font-size: 0.88rem;
    font-weight: 500;
    transition: border-color 0.2s, color 0.2s;
  }
  .contact-link:hover { border-color: var(--accent); color: var(--accent); }

  /* FOOTER */
  footer {
    border-top: 1px solid var(--border);
    padding: 2rem 4rem;
    text-align: center;
    color: var(--muted);
    font-size: 0.8rem;
    font-family: 'DM Mono', monospace;
    letter-spacing: 0.05em;
  }

  /* FULL-WIDTH WRAPPERS */
  .full-width {
    padding: 0;
    max-width: 100%;
  }

  /* ANIMATIONS */
  .fade-up {
    opacity: 0;
    transform: translateY(30px);
    animation: fadeUp 0.7s ease forwards;
  }
  @keyframes fadeUp {
    to { opacity: 1; transform: translateY(0); }
  }
  .fade-up:nth-child(1) { animation-delay: 0.1s; }
  .fade-up:nth-child(2) { animation-delay: 0.25s; }
  .fade-up:nth-child(3) { animation-delay: 0.4s; }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    nav { padding: 1rem 1.5rem; }
    .nav-links { display: none; }
    .hero { padding: 7rem 1.5rem 3rem; }
    .hero-grid { grid-template-columns: 1fr; }
    .hero-avatar { width: 160px; height: 160px; font-size: 3.5rem; margin: 0 auto; }
    section { padding: 4rem 1.5rem; }
    .about-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .products-grid { grid-template-columns: 1fr; }
    .awards-grid { grid-template-columns: 1fr; }
    .skills-grid { grid-template-columns: 1fr; }
    .certs-list { grid-template-columns: 1fr; }
    .metrics-inner { grid-template-columns: repeat(2, 1fr); }
    .metrics-bar { padding: 2rem 1.5rem; }
    .contact-inner { padding: 2.5rem 1.5rem; }
    footer { padding: 1.5rem; }
  }

  /* AWARD PHOTO THUMBNAILS */
  .award-thumb {
    width: 100%; margin-top: 1rem;
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid var(--border);
    max-height: 220px;
  }
  .award-thumb img {
    width: 100%; height: 220px;
    object-fit: cover; object-position: center top;
    display: block;
    transition: transform 0.4s ease;
    filter: grayscale(15%);
  }
  .award-card:hover .award-thumb img {
    transform: scale(1.04);
    filter: grayscale(0%);
  }

  /* TALKS SECTION */
  .talks-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  .talk-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.25s, transform 0.2s;
    position: relative;
  }
  .talk-card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--accent);
    transform: scaleX(0); transform-origin: left;
    transition: transform 0.3s;
  }
  .talk-card:hover::before { transform: scaleX(1); }
  .talk-card:hover { border-color: rgba(232,201,122,0.25); transform: translateY(-3px); }

  .talk-thumb {
    width: 100%; height: 260px;
    overflow: hidden;
    position: relative;
  }
  .talk-thumb img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: center top;
    display: block;
    transition: transform 0.4s ease;
    filter: grayscale(10%);
  }
  .talk-card:hover .talk-thumb img { transform: scale(1.04); filter: grayscale(0%); }

  .talk-thumb-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, transparent 40%, rgba(10,10,10,0.85) 100%);
  }
  .talk-badge {
    position: absolute; top: 0.8rem; left: 0.8rem;
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #0a0a0a;
    background: var(--accent);
    padding: 0.25rem 0.65rem;
    border-radius: 2px;
    font-weight: 600;
  }
  .talk-body {
    padding: 1.4rem 1.6rem 1.6rem;
  }
  .talk-meta {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    color: var(--accent);
    letter-spacing: 0.08em;
    margin-bottom: 0.5rem;
  }
  .talk-card h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.15rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 0.6rem;
    color: var(--text);
  }
  .talk-card p {
    font-size: 0.88rem;
    color: var(--muted);
    line-height: 1.6;
  }
  .talk-org {
    display: inline-flex; align-items: center; gap: 0.4rem;
    margin-top: 1rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text);
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 0.3rem 0.75rem;
  }

  @media (max-width: 900px) {
    .talks-grid { grid-template-columns: 1fr; }
    .talk-thumb { height: 200px; }
  }


  /* ── CERTIFICATIONS FULL SECTION ── */
  .cert-section-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.4rem;
  }
  .cert-card-full {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.25s, transform 0.2s;
    display: flex;
    flex-direction: column;
  }
  .cert-card-full:hover {
    border-color: rgba(232,201,122,0.3);
    transform: translateY(-3px);
  }
  .cert-card-full.featured {
    grid-column: span 1;
  }
  .cert-preview {
    width: 100%;
    height: 160px;
    overflow: hidden;
    background: #fff;
    position: relative;
    cursor: pointer;
  }
  .cert-preview img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    transition: transform 0.4s ease;
  }
  .cert-card-full:hover .cert-preview img { transform: scale(1.05); }
  .cert-preview-overlay {
    position: absolute; inset: 0;
    background: rgba(0,0,0,0);
    display: flex; align-items: center; justify-content: center;
    opacity: 0;
    transition: opacity 0.2s;
  }
  .cert-card-full:hover .cert-preview-overlay { opacity: 1; background: rgba(0,0,0,0.35); }
  .cert-view-btn {
    background: var(--accent);
    color: #0a0a0a;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.4rem 1rem;
    border-radius: 3px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
  }
  .cert-info {
    padding: 1rem 1.2rem 1.2rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .cert-issuer-badge {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.1rem;
  }
  .cert-card-full h4 {
    font-family: 'Playfair Display', serif;
    font-size: 0.98rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.3;
  }
  .cert-meta-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 0.2rem;
  }
  .cert-date {
    font-size: 0.72rem;
    color: var(--muted);
    font-family: 'DM Mono', monospace;
  }
  .cert-skills {
    display: flex; flex-wrap: wrap; gap: 0.3rem;
    margin-top: 0.4rem;
  }
  .cert-skill-tag {
    font-size: 0.67rem;
    padding: 0.18rem 0.5rem;
    background: rgba(232,201,122,0.07);
    border: 1px solid rgba(232,201,122,0.15);
    border-radius: 2px;
    color: var(--muted);
  }
  .cert-footer {
    margin-top: auto;
    padding-top: 0.8rem;
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 0.5rem;
  }
  .cert-id {
    font-size: 0.62rem;
    color: #555;
    font-family: 'DM Mono', monospace;
    word-break: break-all;
  }
  .cert-view-link {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    white-space: nowrap;
    letter-spacing: 0.04em;
    transition: color 0.2s;
  }
  .cert-view-link:hover { color: var(--text); }

  /* Lightbox */
  .cert-lightbox {
    display: none;
    position: fixed; inset: 0; z-index: 9999;
    background: rgba(0,0,0,0.92);
    align-items: center; justify-content: center;
  }
  .cert-lightbox.active { display: flex; }
  .cert-lightbox img {
    max-width: 90vw; max-height: 88vh;
    border-radius: 6px;
    box-shadow: 0 30px 80px rgba(0,0,0,0.7);
  }
  .cert-lightbox-close {
    position: absolute; top: 1.5rem; right: 2rem;
    font-size: 2rem; color: #fff;
    cursor: pointer; line-height: 1;
    background: none; border: none;
    opacity: 0.7; transition: opacity 0.2s;
  }
  .cert-lightbox-close:hover { opacity: 1; }

  @media (max-width: 900px) {
    .cert-section-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .cert-section-grid { grid-template-columns: 1fr; }
  }


  /* ── PROJECTS & CASE STUDIES ── */
  .coming-soon-wrap {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.4rem;
  }
  .coming-soon-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 2rem 1.8rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
    overflow: hidden;
  }
  .coming-soon-card::after {
    content: '';
